{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/backend(.*)",
      "dest": "/api/index"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
